generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum ServiceCategoryType {
  DIGITAL
  IT
}

model SiteSettings {
  id           String   @id @default("default")
  popupEnabled Boolean  @default(false)
  popupImage   String   @default("")
  popupLink    String   @default("/contact")
  popupAlt     String   @default("Special offer")
  heroWebm     String
  heroMp4      String
  heroPoster   String
  updatedAt    DateTime @updatedAt
}

model ServiceCategory {
  id          String              @id
  number      Int
  title       String
  description String
  icon        String
  type        ServiceCategoryType
  sortOrder   Int                 @default(0)
  items       ServiceCategoryItem[]
  updatedAt   DateTime            @updatedAt

  @@index([type, sortOrder])
}

model ServiceCategoryItem {
  id         String          @id @default(uuid())
  categoryId String
  label      String
  sortOrder  Int             @default(0)
  category   ServiceCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@index([categoryId, sortOrder])
}

model BlogPost {
  slug      String   @id
  title     String
  excerpt   String
  content   String   @db.Text
  category  String
  author    String
  date      String
  readTime  String
  image     String
  featured  Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([date])
}

model TeamMember {
  id        String   @id
  name      String
  role      String
  bio       String   @db.Text
  image     String
  linkedin  String?
  twitter   String?
  sortOrder Int      @default(0)
  updatedAt DateTime @updatedAt

  @@index([sortOrder])
}

model Enquiry {
  id        String   @id @default(uuid())
  name      String
  email     String
  phone     String?
  subject   String
  message   String   @db.Text
  createdAt DateTime @default(now())

  @@index([createdAt])
}
