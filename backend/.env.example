# Backend URL (this deployment's public URL)
NEXT_PUBLIC_SITE_URL=http://localhost:3001
BACKEND_URL=https://backend-wolf-ten.vercel.app
NEXT_PUBLIC_BACKEND_URL=https://backend-wolf-ten.vercel.app

# PostgreSQL — REQUIRED on Vercel for contact form + admin saves
#
# Neon (recommended): use the POOLED connection string (host contains "-pooler")
# Example:
# DATABASE_URL=postgresql://user:pass@ep-xxxx-pooler.ap-southeast-1.aws.neon.tech/neondb?sslmode=require
#
# Do NOT use the direct (non-pooler) URL on Vercel serverless.
DATABASE_URL=

# Admin panel credentials — change before production
ADMIN_USER_ID=admin
ADMIN_PASSWORD=wolfrayet-admin-change-me

# Comma-separated frontend origins allowed to call public APIs
ALLOWED_ORIGINS=http://localhost:3000,https://wolfrayetmedia.in,https://www.wolfrayetmedia.in

# Public marketing site (admin "View site" link)
NEXT_PUBLIC_FRONTEND_URL=https://www.wolfrayetmedia.in

# Vercel Blob (required for file uploads in production)
BLOB_READ_WRITE_TOKEN=
